rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && (request.auth.token.admin == true
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.userrole == 'admin');
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasOnlyFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function userCreateFields() {
      return [
        'name',
        'email',
        'userrole',
        'createdAt',
        'addresses',
        'primaryAddressIndex',
        'phone',
        'lastLogin',
        'notificationsUpdatedAt'
      ];
    }

    function userWritableFields() {
      return [
        'name',
        'phone',
        'addresses',
        'primaryAddressIndex',
        'lastLogin',
        'notificationsUpdatedAt'
      ];
    }

    function validClientUserCreate(userId) {
      return isOwner(userId)
        && hasOnlyFields(userCreateFields())
        && request.resource.data.userrole == 'client'
        && request.resource.data.name is string
        && request.resource.data.email is string;
    }

    function validClientUserUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(userWritableFields())
        && (!('name' in request.resource.data) || request.resource.data.name is string)
        && (!('phone' in request.resource.data) || request.resource.data.phone is string)
        && (!('addresses' in request.resource.data) || request.resource.data.addresses is list)
        && (!('primaryAddressIndex' in request.resource.data) || request.resource.data.primaryAddressIndex is int);
    }

    function validOrderCreate() {
      return isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.items is list
        && request.resource.data.total is number
        && request.resource.data.createdAt == request.time;
    }

    function isOrderOwner() {
      return isSignedIn() && resource.data.userId == request.auth.uid;
    }

    function validContactMessage() {
      return hasOnlyFields(['name', 'email', 'message', 'read', 'createdAt'])
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 1
        && request.resource.data.name.size() <= 120
        && request.resource.data.email is string
        && request.resource.data.email.size() >= 3
        && request.resource.data.email.size() <= 254
        && request.resource.data.message is string
        && request.resource.data.message.size() >= 1
        && request.resource.data.message.size() <= 2000
        && request.resource.data.read == false
        && request.resource.data.createdAt == request.time;
    }

    // Public read collections; admin-only writes
    match /menu/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /deals/{dealId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders
    match /orders/{orderId} {
      allow create: if isAdmin() || validOrderCreate();
      allow read: if isAdmin() || isOrderOwner();
      allow update, delete: if isAdmin();
    }

    // Users
    match /users/{userId} {
      allow create: if isAdmin() || validClientUserCreate(userId);
      allow read: if isAdmin() || isOwner(userId);
      allow update: if isAdmin() || (isOwner(userId) && validClientUserUpdate());
      allow delete: if isAdmin();
    }

    // User notifications
    match /users/{userId}/notifications/{notificationId} {
      allow create: if isAdmin() || isOwner(userId);
      allow read: if isAdmin() || isOwner(userId);
      allow update: if isAdmin()
        || (isOwner(userId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read'])
          && request.resource.data.read is bool);
      allow delete: if isAdmin() || isOwner(userId);
    }

    // Drivers
    match /drivers/{driverId} {
      allow read, write: if isAdmin();
    }

    // Contact messages
    match /messages/{messageId} {
      allow create: if validContactMessage();
      allow read, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
